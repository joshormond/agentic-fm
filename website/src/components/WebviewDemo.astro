---
// WebviewDemo.astro
// Animated demo: composited FM + webviewer windows with live script typewriter
// Images: filemaker-file.png (bg) + agentic-fm-blank.png (fg)
//
// Overlay tuning constants live as CSS custom properties on .demo-stage.
// Adjust --ed-l, --ed-t, --ed-w, --ch-l, --ch-t, --ch-w to calibrate
// against the actual screenshot pixels.
//
// Image natural CSS px (from @2x PNG):
//   webviewer: 1326 × 880
//   filemaker:  1224 × 929
// Displayed at: wv=740px wide (scale 0.558), fm=660px wide (scale 0.539)
---

<div class="demo-stage" id="webview-demo">

  <!-- FileMaker file — background window.
       overflow:clip cleanly rounds corners. box-shadow (not filter:drop-shadow)
       keeps no stacking context on this element. -->
  <div class="win fm-win">
    <img src="/filemaker-file.png" alt="FileMaker Pro Invoice Solution" draggable="false" />
  </div>

  <!-- Webviewer — foreground window. Image only; no overlays inside.
       overflow:clip ensures the screenshot is cleanly masked to border-radius. -->
  <div class="win wv-win">
    <img src="/agentic-fm-blank.png" alt="agentic-fm webviewer" draggable="false" />
  </div>

  <!-- Overlay layer — a sibling of wv-win, NOT a child.
       Positioned identically to wv-win (same top/left/width).
       No overflow:hidden here so content is never clipped. -->
  <div class="wv-overlays">
    <div class="ed-overlay" id="demo-editor"></div>
    <div class="chat-overlay" id="demo-chat">
      <div id="demo-chat-inner"></div>
      <div class="typing-dots hidden" id="demo-typing">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>

</div>

<style>
  /* ── Overlay calibration constants ─────────────────────────────────────────
     Adjust these to shift the text overlays if the screenshot is re-exported
     at a different resolution or crop.

     Reference: wv-win displays at 740px wide × 491px tall
       Library panel ends at ~153px, line-gutter ends at ~189px → ed-l
       Chat divider at ~547px → ch-l
       Toolbar rows = ~56px → ed-t / ch-t is lower (below "AI Chat" header)
       Bottom status bar ~27px → ed-b / ch-b is higher (above chat input)
  ── */
  /* ── Overlay calibration — relative to the wv-win top-left corner ──────── */
  .demo-stage {
    --ed-l:  222px;   /* editor text left  (after library panel + line gutter) */
    --ed-t:   62px;   /* editor text top   (below toolbar rows)                */
    --ed-w:  280px;   /* editor text width (up to chat divider)                */
    --ed-b:   28px;   /* editor text gap from bottom of window                 */

    --ch-l:  530px;   /* chat content left (after panel divider)               */
    --ch-t:   87px;   /* chat content top  (below "AI Chat" header bar)        */
    --ch-w:  172px;   /* chat content width                                    */
    --ch-b:  153px;   /* chat content gap from bottom (above input box)        */

    --wv-left:  200px;   /* wv-win left offset within stage — keep in sync     */
    --wv-width: 740px;   /* wv-win display width                               */

    --font-size: 7.5px;
    --line-h:    15px;
  }

  /* ── Stage ─────────────────────────────────────────────────────────────── */
  .demo-stage {
    position:    relative;
    width:       940px;
    height:      560px;
    margin:      0 auto;
    user-select: none;
    overflow:    visible; /* let box-shadows bleed outside */
  }

  /* ── Window frames ──────────────────────────────────────────────────────
     Key rules:
       • box-shadow (NOT filter:drop-shadow) — filter creates a stacking
         context that traps z-index of child elements
       • overflow:clip — clips the screenshot image cleanly to border-radius
         without creating a scroll container
       • No overlays live inside these divs
  ── */
  .win {
    position:      absolute;
    border-radius: 10px;
    overflow:      clip;
  }

  .win img {
    display: block;
    width:   100%;
  }

  /* FileMaker — behind, lower-left */
  .fm-win {
    top:   62px;
    left:  0;
    width: 660px;
    z-index: 0;
  }

  /* Webviewer — in front, upper-right */
  .wv-win {
    top:   0;
    left:  var(--wv-left);
    width: var(--wv-width);
    z-index: 1;
  }

  /* ── Overlay context ────────────────────────────────────────────────────
     A transparent sibling of wv-win — same top/left/width as wv-win.
     Overlays live here so they are never clipped by wv-win's overflow:clip.
     aspect-ratio keeps the height in sync with the image automatically.
  ── */
  .wv-overlays {
    position:     absolute;
    top:          0;
    left:         var(--wv-left);
    width:        var(--wv-width);
    aspect-ratio: 1326 / 880;  /* exact natural px ratio of agentic-fm-blank.png */
    z-index:      2;           /* above both windows */
    pointer-events: none;
  }

  /* ── Editor overlay ───────────────────────────────────────────────────── */
  .ed-overlay {
    position: absolute;
    left:     var(--ed-l);
    top:      var(--ed-t);
    width:    var(--ed-w);
    bottom:   var(--ed-b);
    overflow: hidden;

    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', Menlo, monospace;
font-weight: 600;
    font-size:   var(--font-size);
    line-height: var(--line-h);
    color:       #d4d4d4;
    white-space: pre;
  }

  /* ── Chat overlay ─────────────────────────────────────────────────────── */
  .chat-overlay {
    position: absolute;
    left:     var(--ch-l);
    top:      var(--ch-t);
    width:    var(--ch-w);
    bottom:   var(--ch-b);
    overflow: hidden;

    display:        flex;
    flex-direction: column;
    gap:            6px;
    padding:        2px 1px;
  }

  /* ── Code line ────────────────────────────────────────────────────────── */
  :global(.cl) {
    display:    block;
    min-height: var(--line-h);
    position:   relative;
  }

  /* # prompt: line highlight */
  :global(.cl-prompt) {
    background:    rgba(255, 214, 0, 0.09);
    border-left:   2px solid rgba(255, 214, 0, 0.75);
    margin-left:   -6px;
    padding-left:  4px;
    border-radius: 0 2px 2px 0;
  }

  /* ── Chat bubbles ─────────────────────────────────────────────────────── */
  :global(.cb) {
    border-radius: 7px;
    padding:       5px 8px;
    margin-bottom: 10px;
    font-family:   -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size:     10.5px;
    line-height:   1.45;
    word-break:    break-word;
    flex-shrink:   0;
  }

  :global(.cb-user) {
    background: rgba(255,255,255,0.10);
    color:      #c8c8e8;
    border:     1px solid rgba(255,255,255,0.15);
  }

  :global(.cb-ai) {
    background: rgba(50,130,210,0.35);
    color:      #deeffe;
    border:     1px solid rgba(50,130,210,0.50);
  }

  /* ── Typing indicator ─────────────────────────────────────────────────── */
  .typing-dots {
    display:       flex;
    gap:           3px;
    padding:       6px 9px;
    background:    rgba(50,130,210,0.16);
    border-radius: 7px;
    width:         fit-content;
    border:        1px solid rgba(50,130,210,0.22);
    flex-shrink:   0;
  }

  .typing-dots span {
    display:       block;
    width:         4px;
    height:        4px;
    border-radius: 50%;
    background:    #60aaf0;
    animation:     tdot 1.1s infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.17s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.34s; }

  @keyframes tdot {
    0%, 55%, 100% { opacity: 0.2; transform: translateY(0); }
    27%            { opacity: 1;   transform: translateY(-3px); }
  }

  /* ── Cursor ───────────────────────────────────────────────────────────── */
  :global(.cur) {
    display:        inline-block;
    width:          1.5px;
    height:         12px;
    background:     #b0b0b0;
    vertical-align: text-bottom;
    margin-left:    1px;
    animation:      cblink 1s step-end infinite;
  }

  @keyframes cblink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  /* ── Chat panel attention glow ────────────────────────────────────────── */
  @keyframes ch-glow {
    0%   { box-shadow: 0 0 0  0px rgba(50,130,210,0);    }
    35%  { box-shadow: 0 0 0  3px rgba(50,130,210,0.50); }
    100% { box-shadow: 0 0 0  6px rgba(50,130,210,0);    }
  }

  .chat-pulsing { animation: ch-glow 1s ease-out; }

  .hidden { display: none !important; }

  /* ── Responsive scale — handled by JS ResizeObserver below ────────────── */
  .demo-stage {
    transform-origin: top left; /* JS translates to center after scaling */
  }
</style>

<script>
  // ─── Syntax token colors (VS Code Dark+ palette) ─────────────────────────
  const C = {
    comment: '#6a9955',
    keyword: '#c586c0',   // If, Loop, End If, End Loop
    step:    '#9cdcfe',   // step names
    bracket: '#b8b8b8',   // [ ] ; punctuation
    string:  '#ce9178',   // "quoted strings"
    field:   '#dcdcaa',   // Table::Field
    varr:    '#4fc1ff',   // $variables
    prompt:  '#ffd600',   // # prompt: text
  };

  // ─── Script sequences ─────────────────────────────────────────────────────
  const SCRIPTS = [
    {
      label: 'New Invoice for Client',
      chat:  'Create a new Invoice and link it to the active Client record.',
      lines: [
        { k: 'comment', t: '# ──────────────────────────────────────────────────' },
        { k: 'comment', t: '# Purpose:  Create a new Invoice for current Client' },
        { k: 'comment', t: '# ──────────────────────────────────────────────────' },
        { k: 'blank' },
        { k: 'tokens', toks: [[C.step,'Set Variable'],[C.bracket,' [ '],[C.varr,'$clientKey'],[C.bracket,' ; '],[C.field,'Clients Primary::PrimaryKey'],[C.bracket,' ]']] },
        { k: 'tokens', toks: [[C.step,'Go to Layout'],[C.bracket,' [ '],[C.string,'"Invoices Details"'],[C.bracket,' ; Animation: None ]']] },
        { k: 'tokens', toks: [[C.step,'New Record/Request']] },
        { k: 'tokens', toks: [[C.step,'Set Field'],[C.bracket,' [ '],[C.field,'Invoices::ForeignKeyClient'],[C.bracket,' ; '],[C.varr,'$clientKey'],[C.bracket,' ]']] },
        { k: 'blank' },
        { k: 'prompt', t: 'prompt: Add error handling after New Record/Request' },
      ],
      ai: 'Ok, completing your request. Will add If [ Get(LastError) ≠ 0 ] after New Record/Request — shows an error dialog then exits cleanly.',
    },
    {
      label: 'Sort Invoices',
      chat:  'Sort invoices and track which column is active.',
      lines: [
        { k: 'comment', t: '# ──────────────────────────────────────────────────' },
        { k: 'comment', t: '# Purpose:  Sort Invoices and track sort state' },
        { k: 'comment', t: '# ──────────────────────────────────────────────────' },
        { k: 'blank' },
        { k: 'tokens', toks: [[C.keyword,'If'],[C.bracket,' [ '],[C.field,'Get(FoundCount)'],[C.bracket,' = 0 ]']] },
        { k: 'tokens', toks: [[C.step,'  Exit Script'],[C.bracket,' [ Text Result: '],[C.string,'""'],[C.bracket,' ]']] },
        { k: 'tokens', toks: [[C.keyword,'End If']] },
        { k: 'blank' },
        { k: 'tokens', toks: [[C.step,'Sort Records'],[C.bracket,' [ Restore ; No Dialog ]']] },
        { k: 'blank' },
        { k: 'prompt', t: 'prompt: Set a global to track the active sort column' },
      ],
      ai: 'Ok, completing your request. Will add Set Variable [ $$invoicesSort ; "date_desc" ] after Sort Records so column headers stay in sync.',
    },
    {
      label: 'Apply Line Item Discount',
      chat:  'Apply a discount to every Line Item in the found set.',
      lines: [
        { k: 'comment', t: '# ──────────────────────────────────────────────────' },
        { k: 'comment', t: '# Purpose:   Apply discount to all Line Items' },
        { k: 'comment', t: '# PARAMETER: discount as decimal  (e.g. 0.10)' },
        { k: 'comment', t: '# ──────────────────────────────────────────────────' },
        { k: 'blank' },
        { k: 'tokens', toks: [[C.step,'Set Variable'],[C.bracket,' [ '],[C.varr,'$discount'],[C.bracket,' ; '],[C.field,'Get(ScriptParameter)'],[C.bracket,' ]']] },
        { k: 'tokens', toks: [[C.step,'Go to Record/Request/Page'],[C.bracket,' [ First ]']] },
        { k: 'tokens', toks: [[C.keyword,'Loop']] },
        { k: 'tokens', toks: [[C.step,'  Set Field'],[C.bracket,' [ '],[C.field,'Line Items::Amount'],[C.bracket,' ; '],[C.field,'Line Items::Amount'],[C.bracket,' * (1 - '],[C.varr,'$discount'],[C.bracket,') ]']] },
        { k: 'tokens', toks: [[C.step,'  Go to Record/Request/Page'],[C.bracket,' [ Next ; Exit After Last ]']] },
        { k: 'tokens', toks: [[C.keyword,'End Loop']] },
        { k: 'blank' },
        { k: 'prompt', t: 'prompt: Commit each record and handle commit errors' },
      ],
      ai: 'Ok, completing your request. Will add Commit Records/Requests inside the loop with If [ Get(LastError) ≠ 0 ] — exits and reports which record failed.',
    },
  ];

  // ─── Speed config ─────────────────────────────────────────────────────────
  const SPEED = {
    char:        25,   // ms per character (code)
    commentChar: 16,   // ms per character (comments, slightly faster)
    aiChar:      17,   // ms per character (AI response)
    lineGap:     60,   // ms pause between lines
    promptPause: 1050, // ms to hold on # prompt: before triggering AI
    aiDelay:     680,  // ms typing indicator shows before AI text appears
    hold:        2600, // ms to hold after AI response before next script
  };

  // ─── DOM refs ─────────────────────────────────────────────────────────────
  const edEl     = document.getElementById('demo-editor');
  const chatInEl = document.getElementById('demo-chat-inner');
  const typingEl = document.getElementById('demo-typing');
  const chatEl   = document.getElementById('demo-chat');

  // ─── Utilities ────────────────────────────────────────────────────────────
  const sleep = ms => new Promise(r => setTimeout(r, ms));

  async function typeInto(el, text, msPerChar) {
    for (const ch of text) {
      el.textContent += ch;
      await sleep(msPerChar);
    }
  }

  function makeBubble(isAi) {
    const d = document.createElement('div');
    d.className = 'cb ' + (isAi ? 'cb-ai' : 'cb-user');
    chatInEl.appendChild(d);
    return d;
  }

  // ─── Type a single line into the editor ───────────────────────────────────
  async function typeLine(line) {
    const isPrompt = line.k === 'prompt';

    const row = document.createElement('span');
    row.className = 'cl' + (isPrompt ? ' cl-prompt' : '');

    // Blinking cursor appended last; all spans inserted before it
    const cur = document.createElement('span');
    cur.className = 'cur';
    row.appendChild(cur);
    edEl.appendChild(row);

    if (line.k === 'blank') {
      cur.remove();
      row.textContent = '\n';
      return;
    }

    if (line.k === 'comment') {
      const s = document.createElement('span');
      s.style.color = C.comment;
      row.insertBefore(s, cur);
      await typeInto(s, line.t, SPEED.commentChar);

    } else if (line.k === 'prompt') {
      // "# " dimmed
      const hash = document.createElement('span');
      hash.style.color = '#888';
      row.insertBefore(hash, cur);
      await typeInto(hash, '# ', SPEED.char);

      // "prompt: …" in gold italic
      const gold = document.createElement('span');
      gold.style.color = C.prompt;
      gold.style.fontStyle = 'italic';
      row.insertBefore(gold, cur);
      await typeInto(gold, line.t, SPEED.char);

    } else if (line.k === 'tokens') {
      for (const [color, text] of line.toks) {
        const s = document.createElement('span');
        s.style.color = color;
        row.insertBefore(s, cur);
        for (const ch of text) {
          s.textContent += ch;
          await sleep(SPEED.char);
        }
      }
    }

    cur.remove();
  }

  // ─── Run one full script sequence ─────────────────────────────────────────
  async function runScript(script) {
    edEl.innerHTML      = '';
    chatInEl.innerHTML  = '';
    typingEl.classList.add('hidden');

    // User message appears at the top of the chat panel
    const userBubble = makeBubble(false);
    await typeInto(userBubble, script.chat, SPEED.aiChar);
    await sleep(280);

    // Type each line of the script
    for (const line of script.lines) {
      await typeLine(line);
      if (line.k !== 'blank') await sleep(SPEED.lineGap);
    }

    // Pause on the # prompt: line, then show the inline-prompt instruction bubble
    await sleep(SPEED.promptPause);

    const promptBubble = makeBubble(false);
    await typeInto(promptBubble, 'Interpret my inline # prompts', SPEED.aiChar);
    await sleep(280);

    // Draw attention to the chat panel with a glow pulse
    chatEl.classList.add('chat-pulsing');
    chatEl.addEventListener('animationend', () => chatEl.classList.remove('chat-pulsing'), { once: true });

    // Show typing indicator → AI response
    typingEl.classList.remove('hidden');
    await sleep(SPEED.aiDelay);
    typingEl.classList.add('hidden');

    const aiBubble = makeBubble(true);
    await typeInto(aiBubble, script.ai, SPEED.aiChar);

    await sleep(SPEED.hold);
  }

  // ─── Continuous loop ──────────────────────────────────────────────────────
  async function loop() {
    let i = 0;
    for (;;) {
      await runScript(SCRIPTS[i++ % SCRIPTS.length]);
    }
  }

  // Start only when the component enters the viewport
  const io = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      io.disconnect();
      loop();
    }
  }, { threshold: 0.2 });

  const stage = document.getElementById('webview-demo');
  if (stage) io.observe(stage);

  // ─── Responsive scaling ───────────────────────────────────────────────────
  // transform: scale() does not affect layout — the stage stays 940px wide in
  // the document flow. We compute the scale from the parent width and apply a
  // translateX to keep it centered, then collapse the dead vertical space with
  // a negative margin-bottom.
  const STAGE_W = 940;
  const STAGE_H = 560;

  function applyScale() {
    if (!stage) return;
    const available = stage.parentElement.clientWidth;
    if (available >= STAGE_W) {
      // Enough room — reset any inline styles
      stage.style.transform = '';
      stage.style.marginBottom = '';
      return;
    }
    const scale  = available / STAGE_W;
    const tx     = (available - STAGE_W * scale) / 2; // center after scaling
    stage.style.transform    = `translateX(${tx}px) scale(${scale})`;
    stage.style.marginBottom = `${(STAGE_H * scale) - STAGE_H}px`;
  }

  const ro = new ResizeObserver(applyScale);
  if (stage) ro.observe(stage.parentElement);
  applyScale();
</script>
